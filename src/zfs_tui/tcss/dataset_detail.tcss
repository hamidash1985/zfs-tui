#dataset-detail-layout {
    height: 1fr;
}

#dataset-detail-title {
    background: $primary-darken-1;
    color: $text;
    text-style: bold;
    padding: 0 2;
    height: 1;
}

#dataset-info {
    padding: 1;
}

#props-title, #bookmarks-title {
    padding: 1 1 0 1;
    text-style: bold;
}

#snapshot-actions {
    height: 3;
    align: center middle;
}

#snap-btn, #rollback-btn, #clone-btn, #delete-snap-btn {
    min-width: 16;
}
